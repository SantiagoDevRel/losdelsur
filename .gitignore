# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel

# Generados por scripts/sync-audio.ts desde content/ en el prebuild.
# La fuente de verdad vive en content/ — estos son solo copias.
/public/audio/
/public/covers/

# Service Worker generado por Serwist en build — no commitear.
/public/sw.js
/public/swe-worker-*.js

# Python / scripts
__pycache__/
*.pyc

# Design handoff — assets source (no deployeados)
/public/design-assets/

# Capacitor — build artefacts de Android. El folder `android/` SÍ se
# commitea (es el proyecto nativo), pero estos son outputs de Gradle.
/android/app/build/
/android/build/
/android/.gradle/
/android/local.properties
/android/.idea/
/android/app/release/
/android/app/debug/
*.apk
*.aab
*.keystore
!debug.keystore
